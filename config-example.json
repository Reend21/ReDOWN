{
  "general-info": {
    "version": "1.0",
    "appName": "Re://DOWN",
    "lastChange": "2025-05-30T00:00:00.000Z",
    "docs": "https://github.com/Reend21/redown/doc"
  },

  "server": {
    "port": 3000,
    "host": "127.0.0.1",
    "basePath": "/",
    "allowedOrigins": ["http://localhost:3000"]
  },

  "downloader": {
    "defaultSavePath": "~/Downloads/redown",
    "parallel": 3,
    "bandwidthLimit": null,
    "proxy": null,
    "ytdlpPath": "yt-dlp",
    "ffmpegPath": "ffmpeg",
    "ytdlpFlags": [],
    "cookiesEnabled": false,
    "cookiesPath": null,
    "sponsorblock": {
      "behavior": "remove",
      "categories": ["sponsor", "selfpromo", "interaction"]
    },
    "retryCount": 3,
    "duplicateWarning": true
  },

  "formats": {
    "video": ["mp4", "mkv"],
    "audio": ["mp3", "opus", "flac"],
    "defaultVideoFormat": "mp4",
    "defaultAudioFormat": "mp3",
    "defaultResolution": "1080p",
    "embedThumbnail": true,
    "embedMetadata": true,
    "subtitles": {
      "enabled": false,
      "langs": ["tr", "en"],
      "format": "srt",
      "autoGenerated": false
    }
  },

  "scheduler": {
    "enabled": false,
    "timezone": "auto",
    "jobs": []
  },

  "history": {
    "enabled": true,
    "maxEntries": 500,
    "saveFailedDownloads": false
  },

  "ui": {
    "theme": "system",
    "accentColor": "#7c8cf8",
    "borderRadius": "medium",
    "fontSize": 1.0,
    "scale": 1.0,
    "compactMode": false,
    "backgroundBlur": false,
    "animations": true,
    "customCSSEnabled": false,
    "language": "auto"
  },

  "privacy": {
    "errorReporting": false,
    "telemetry": false
  },

  "advanced": {
    "logLevel": "warn",
    "logFile": null,
    "maxLogSizeMB": 10
  }
}